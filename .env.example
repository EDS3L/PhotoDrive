# PhotoDrive — szablon zmiennych środowiskowych.
# Skopiuj do `.env` (`cp .env.example .env`) i wypełnij WŁASNYMI wartościami.
# `.env` jest w .gitignore — NIGDY nie commituj prawdziwych sekretów.
# Ten plik czyta docker-compose.yml (dev); prod bierze wartości z sekretów GitHub Actions.

# --- Baza danych (MySQL 8) ---
DATASOURCE_URL=jdbc:mysql://localhost:3306/photodrive
DATASOURCE_USERNAME=photodrive
DATASOURCE_PASSWORD=change-me

# --- Poczta (SMTP, STARTTLS na :587) ---
MAIL_HOST=smtp.example.com
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=change-me

# --- JWT ---
# Klucz HS256: base64 co najmniej 256-bitowego sekretu. Wygeneruj np.:
#   openssl rand -base64 32
TOKEN_SECRETKEY=change-me-base64-256-bit-secret
# TTL sesji w minutach (domyślnie 60, jeśli pominięte).
JWT_ACCESS_TTL_MINUTES=60

# --- Storage plików ---
# Katalog na oryginały i miniatury oraz katalog tymczasowy uploadu.
DIR=/app/photodrive/
STORAGE_TEMP_PATH=/app/photodrive-temp
# Maksymalny rozmiar pojedynczego uploadu w MB.
ORG_MAX_SIZE=20

# --- Swagger UI (osobny login do /swagger-ui) ---
SWAGGER_USER=swagger
SWAGGER_PASSWORD=change-me

# --- Ciasteczko / origin ---
# Poza HTTPS (lokalny dev) ustaw false, inaczej przeglądarka nie odeśle cookie `pd_at`.
COOKIE_SECURE=false
